# CoCoDems CRM — local Docker environment
# Copy to the repository root: cp .env.example .env
#
# This file is for LOCAL development only. Staging/production use a separate
# .env on the EC2 server with CIVICRM_UF_BASEURL set to your public domain.
# See infra/terraform/environments/staging/README.md.
#
# If passwords contain $, escape each dollar sign as $$ (Docker Compose treats
# $VAR as variable substitution and will warn or corrupt values otherwise).

# --- HTTP ---

# Port for the local site (http://localhost:8080)
HTTP_PORT=8080

# Public URL WordPress and CiviCRM use for links and redirects
CIVICRM_UF_BASEURL=http://localhost:8080

# --- Database (MariaDB) ---

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=cocodems
MYSQL_USER=cocodems
MYSQL_PASSWORD=change-me

# --- WordPress / CiviCRM admin (created on first boot) ---

WORDPRESS_SITE_TITLE=CoCoDems CRM
CIVICRM_ADMIN_USER=admin
CIVICRM_ADMIN_PASS=change-me
CIVICRM_ADMIN_EMAIL=admin@example.com

# --- Backups / staging → local sync ---
# Used by backup-db.sh, sync-staging-to-local.sh, rebuild-local-from-staging.sh
# Same bucket as staging: terraform output -raw backup_bucket_name

# BACKUP_S3_BUCKET=cocodems-staging-columbia-backups-UNIQUE-SUFFIX

# Optional: refresh staging files archive via SSM during local rebuild
# AWS_REGION=us-east-2
# STAGING_EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# --- Optional build overrides (pinned by rebuild-local-from-staging.sh) ---

# CIVICRM_VERSION=6.16.0
# WORDPRESS_VERSION=7.0.1
