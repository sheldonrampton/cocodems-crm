# CoCoDems CRM — local Docker environment
# Copy to the repository root: cp .env.example .env
#
# This file is for LOCAL development only. Staging/production use a separate
# .env on the EC2 server with CIVICRM_UF_BASEURL set to your public domain.
# See infra/terraform/environments/staging/README.md.

# --- HTTP ---

# Port for the local site (http://localhost:8080)
HTTP_PORT=8080

# Public URL WordPress and CiviCRM use for links and redirects
CIVICRM_UF_BASEURL=http://localhost:8080

# --- Database (MariaDB) ---

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=cocodems
MYSQL_USER=cocodems
MYSQL_PASSWORD=change-me

# --- WordPress / CiviCRM admin (created on first boot) ---

WORDPRESS_SITE_TITLE=CoCoDems CRM
CIVICRM_ADMIN_USER=admin
CIVICRM_ADMIN_PASS=change-me
CIVICRM_ADMIN_EMAIL=admin@example.com

# --- Domain (staging/production only; ignored by local Docker) ---
# See docs/dns.md for DNS setup instructions.

# SITE_DOMAIN=crm.example.org

# --- Optional build overrides ---

# CIVICRM_VERSION=6.0.3
# WORDPRESS_VERSION=
