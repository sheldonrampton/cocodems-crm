# Staging server environment — copy to /opt/cocodems-crm/.env on the EC2 instance.
# Do NOT use this file for local Docker (use .env.example at repo root instead).
#
# If passwords contain $, escape each dollar sign as $$ (Docker Compose treats
# $VAR as variable substitution and will warn or corrupt values otherwise).

# --- HTTP (Docker binds 127.0.0.1:8080 via docker-compose.staging.yml; host Nginx serves the public domain) ---
# HTTP_PORT is used by local Docker only — staging ignores it.

HTTP_PORT=8080

# Use http:// on first deploy; setup-staging-tls.sh switches this to https://
CIVICRM_UF_BASEURL=http://crm-staging.example.org

SITE_DOMAIN=crm-staging.example.org

# --- Database (MariaDB) ---

MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=cocodems
MYSQL_USER=cocodems
MYSQL_PASSWORD=change-me

# --- WordPress / CiviCRM admin (created on first boot) ---

WORDPRESS_SITE_TITLE=CoCoDems CRM (Staging)
CIVICRM_ADMIN_USER=admin
CIVICRM_ADMIN_PASS=change-me
CIVICRM_ADMIN_EMAIL=admin@example.com

# --- Backups (optional; scripts/backup-db.sh --upload) ---
# S3 bucket from: terraform output -raw backup_bucket_name
# BACKUP_S3_BUCKET=cocodems-staging-columbia-backups-UNIQUE-SUFFIX

# --- Optional: staging HTTP basic auth (scripts/setup-staging-auth.sh) ---

# STAGING_HTTP_USER=staging
# STAGING_HTTP_PASS=change-me

# --- Optional build overrides ---

# CIVICRM_VERSION=6.16.0
# WORDPRESS_VERSION=
