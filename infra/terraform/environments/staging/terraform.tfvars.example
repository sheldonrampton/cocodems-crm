# Copy to terraform.tfvars and edit before running terraform plan/apply.
# Do not commit terraform.tfvars — it may contain account-specific values.

aws_region   = "us-east-2"
project_name = "cocodems"
county_slug  = "columbia"

# Public hostname for staging. DNS is configured manually — see docs/dns.md.
site_domain = "crm-staging.example.org"

# Must be globally unique across all AWS accounts.
backup_bucket_name = "cocodems-staging-columbia-backups-UNIQUE-SUFFIX"

instance_type       = "t3.small"
root_volume_size_gb = 30

# Restrict SSH to your IP, or leave empty and use SSM Session Manager:
# ssh_allowed_cidrs = ["203.0.113.10/32"]
ssh_allowed_cidrs = []

# Optional EC2 key pair (create in AWS console first):
# key_name = "your-keypair-name"
